# ClickNShop.bd - Environment Variables Template
# =============================================
# Copy this file to .env (local dev) and fill in values.
# For Hostinger production, add these as Environment Variables in dashboard.
#
# IMPORTANT (Updated 2026-07-16 per Boss's insight):
# Local development AND Hostinger production BOTH use the same
# Neon PostgreSQL database. No more SQLite vs PostgreSQL confusion!
# =============================================

# =============================================
# DATABASE (Neon PostgreSQL)
# =============================================
# Get from: https://console.neon.tech → clicknshop-bd project → Connect → Pooled connection
# IMPORTANT: Use POOLED connection (with -pooler in hostname)
DATABASE_URL="postgresql://neondb_owner:YOUR_PASSWORD@ep-rapid-star-atd0slal-pooler.c-9.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# =============================================
# AI (Groq)
# =============================================
# Get from: https://console.groq.com/keys
GROQ_API_KEY="gsk_YOUR_GROQ_KEY_HERE"

# =============================================
# AUTH SECRETS
# =============================================
# Generate NEXTAUTH_SECRET:
#   PowerShell: [Convert]::ToBase64String((1..32 | ForEach-Object { Get-Random -Max 256 }) -join '' )
NEXTAUTH_SECRET="YOUR_NEXTAUTH_SECRET_HERE"

# Generate ENCRYPTION_KEY (32 hex chars):
#   PowerShell: -join ((1..32 | ForEach-Object { '{0:x2}' -f (Get-Random -Max 256) }))
ENCRYPTION_KEY="YOUR_32_CHAR_HEX_ENCRYPTION_KEY"

# =============================================
# APP CONFIGURATION
# =============================================
# Set to "true" for direct dashboard access without login (recommended for single-user mode)
BYPASS_MODE_ENABLED="true"

# Public app name (shown in UI)
NEXT_PUBLIC_APP_NAME="ClickNShop.bd"

# Local dev URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Production URL (used in Hostinger env vars, not in local .env)
# NEXTAUTH_URL="https://navajowhite-snake-854284.hostingersite.com"

# =============================================
# NODE ENV
# =============================================
# In Hostinger env vars: NODE_ENV=production
# Local dev: not needed (Next.js auto-detects)